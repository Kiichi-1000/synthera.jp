# https://resend.com で API キーを取得（無料枠あり）
RESEND_API_KEY=re_xxxxxxxxxxxx

# 受信メール（未設定時は synthera.2025@gmail.com）
CONTACT_TO=synthera.2025@gmail.com

# 送信元。未設定時は Resend の検証用ドメイン（本番では自社ドメインの検証を推奨）
