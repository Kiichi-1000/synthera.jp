# https://resend.com で API キーを取得（無料枠あり）
RESEND_API_KEY=re_xxxxxxxxxxxx

# 受信メール（未設定時は synthera.2025@gmail.com）
CONTACT_TO=synthera.2025@gmail.com

# 送信元。未設定時は Resend の検証用ドメイン（本番では自社ドメインの検証を推奨）
# RESEND_FROM=Synthera <onboarding@resend.dev>

# 通常は未設定でOK（/api/contact を使用）
# 静的配信時のみ、外部フォームAPIを使う場合に設定（例: Formspree / 自前API）
# NEXT_PUBLIC_CONTACT_ENDPOINT=https://example.com/api/contact

# カスタムドメイン未使用で Project Pages 配信する場合のみ設定（例: /synthera-web-new2）
# NEXT_PUBLIC_BASE_PATH=
